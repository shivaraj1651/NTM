# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ntm:ntm_dev@localhost:5432/ntm
POSTGRES_USER=ntm
POSTGRES_PASSWORD=ntm_dev
POSTGRES_DB=ntm

MONGODB_URL=mongodb://ntm:ntm_dev@localhost:27017
MONGO_USER=ntm
MONGO_PASSWORD=ntm_dev

REDIS_URL=redis://localhost:6379/0

# ── Object Storage (MinIO / S3) ──────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=ntm-assets
AWS_REGION=ap-south-1
AWS_ACCESS_KEY=minioadmin
AWS_SECRET_KEY=minioadmin
MINIO_ROOT_USER=ntm_minio
MINIO_ROOT_PASSWORD=ntm_minio_dev

# ── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Platform APIs ────────────────────────────────────────────────────────────
# Google Ads — https://developers.google.com/google-ads/api/docs/get-started
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=          # 10-digit MCC or advertiser account ID (no dashes)

# Meta Ads — https://developers.facebook.com/docs/marketing-apis
META_APP_ID=
META_APP_SECRET=
META_SYSTEM_USER_TOKEN=          # System user access token with ads_management scope
META_AD_ACCOUNT_ID=              # Numeric ad account ID (without act_ prefix)
META_PAGE_ID=                    # Facebook Page ID used as ad identity

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Developer / Test Mode ─────────────────────────────────────────────────────
# NTM_ADS_TEST_MODE=1 → real API calls, campaigns created PAUSED with [TEST] prefix
# NTM_STUB_EXTERNAL=1 → fully fake/stubbed — no real API calls at all
NTM_ADS_TEST_MODE=1
NTM_STUB_EXTERNAL=0

# ── Analytics ────────────────────────────────────────────────────────────────
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON_PATH=

# ── Research ─────────────────────────────────────────────────────────────────
SERPAPI_KEY=
PERPLEXITY_API_KEY=

# ── Creative Generation ──────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
STABILITY_AI_API_KEY=
RUNWAY_API_KEY=

# ── Email ────────────────────────────────────────────────────────────────────
AWS_SES_FROM_EMAIL=noreply@example.com

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
